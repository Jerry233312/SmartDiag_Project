# 复制此文件为 .env 并填入真实密钥
# cp .env.example .env
# ⚠️  .env 已被 .gitignore 排除，绝不会提交到版本库

# 腾讯 LKE 知识引擎 Bot 密钥
BOT_APP_KEY=your_bot_app_key_here

# 腾讯云 API 密钥
SECRET_ID=your_secret_id_here
SECRET_KEY=your_secret_key_here

# LKE SSE 接口地址（一般无需修改）
LKE_SSE_URL=https://wss.lke.cloud.tencent.com/v1/qbot/chat/sse
